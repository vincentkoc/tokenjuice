{
  "id": "tests/pytest",
  "family": "test-results",
  "description": "Compact pytest output while preserving failures and final summary.",
  "match": {
    "toolNames": ["exec"],
    "commandIncludes": ["pytest"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "filters": {
    "skipPatterns": [
      "^platform .+",
      "^rootdir: .+",
      "^plugins: .+"
    ]
  },
  "summarize": {
    "head": 12,
    "tail": 10
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 18,
    "tail": 18
  },
  "counters": [
    {
      "name": "failed test",
      "pattern": "FAILED",
      "flags": "i"
    },
    {
      "name": "passed test",
      "pattern": "PASSED",
      "flags": "i"
    }
  ]
}

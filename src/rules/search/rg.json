{
  "id": "search/rg",
  "family": "search",
  "description": "Compact ripgrep output while preserving match lines.",
  "match": {
    "argv0": ["rg"],
    "toolNames": ["exec"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 12,
    "tail": 4
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 16,
    "tail": 10
  },
  "counters": [
    {
      "name": "match",
      "pattern": ".+:.+"
    }
  ]
}

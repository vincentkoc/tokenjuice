{
  "id": "tests/vitest",
  "family": "test-results",
  "description": "Compact Vitest output while preserving failures and summary lines.",
  "match": {
    "toolNames": ["exec"],
    "commandIncludes": ["vitest"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "filters": {
    "skipPatterns": [
      "^\\s*at .+",
      "^\\s*❯ .+node_modules.+"
    ]
  },
  "summarize": {
    "head": 12,
    "tail": 10
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 18,
    "tail": 18
  },
  "counters": [
    {
      "name": "failed suite",
      "pattern": "^\\s*❯\\s.+",
      "flags": "m"
    },
    {
      "name": "failed",
      "pattern": "failed",
      "flags": "i"
    }
  ]
}

{
  "id": "tests/pnpm-test",
  "family": "test-results",
  "description": "Catch common pnpm test runs when the underlying runner is not explicit.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["pnpm"],
    "argvIncludes": [["test"]]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 12,
    "tail": 10
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 16,
    "tail": 16
  },
  "counters": [
    {
      "name": "failed",
      "pattern": "fail",
      "flags": "i"
    },
    {
      "name": "passed",
      "pattern": "pass",
      "flags": "i"
    }
  ]
}

{
  "id": "tests/go-test",
  "family": "test-results",
  "description": "Compact go test output while preserving failing packages and summaries.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["go"],
    "argvIncludes": [["test"]]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 12,
    "tail": 10
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 18,
    "tail": 18
  },
  "counters": [
    {
      "name": "failed package",
      "pattern": "^FAIL\\s",
      "flags": "m"
    },
    {
      "name": "passed package",
      "pattern": "^ok\\s",
      "flags": "m"
    }
  ]
}

{
  "id": "filesystem/ls",
  "family": "filesystem-listing",
  "description": "Compact ls output for directory listings.",
  "match": {
    "toolNames": ["exec"],
    "argv0": ["ls"]
  },
  "transforms": {
    "stripAnsi": true,
    "dedupeAdjacent": true,
    "trimEmptyEdges": true
  },
  "summarize": {
    "head": 14,
    "tail": 4
  },
  "failure": {
    "preserveOnFailure": true,
    "head": 16,
    "tail": 10
  },
  "counters": [
    {
      "name": "item",
      "pattern": ".+"
    }
  ]
}
